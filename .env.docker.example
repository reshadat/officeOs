# Copy to .env before docker-compose up
# docker-compose automatically loads .env from the same directory

# OpenAI key — used by Codex runtime workers
OPENAI_API_KEY=sk-...

# Anthropic key — optional if using claude login (interactive OAuth)
# Required if running headless / CI
ANTHROPIC_API_KEY=sk-ant-...

# Path to the workspace your agents will work on (host path)
# Only this directory is mounted — limits blast radius
WORKSPACE_PATH=/path/to/your/project
